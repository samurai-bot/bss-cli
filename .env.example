# BSS-CLI .env example. Copy to .env, then fill in the placeholders.
# Updated through v0.16; reflects every env var any service / portal /
# CLI reads at startup. Sensitive values are documented placeholders;
# never commit a real secret to .env.example.

# ════════════════════════════════════════════════════════════════════
# Infrastructure connection strings
# ════════════════════════════════════════════════════════════════════
# All-in-one (docker-compose.infra.yml): use compose service names
#   BSS_DB_URL=postgresql+asyncpg://bss:bss@postgres:5432/bss
#   BSS_MQ_URL=amqp://guest:guest@rabbitmq:5672/
# BYOI (bring-your-own-infra): point at your infrastructure endpoints.
BSS_DB_URL=postgresql+asyncpg://bss:bss@postgres:5432/bss
BSS_MQ_URL=amqp://guest:guest@rabbitmq:5672/

# ════════════════════════════════════════════════════════════════════
# Application
# ════════════════════════════════════════════════════════════════════
# `BSS_ENV` is doctrine, not a string. Many startup guards key on
# `BSS_ENV=production` (sk_test_* refusal, prebaked-KYC refusal, PCI
# template scan, etc.). Set it honestly per deployment.
BSS_ENV=development
BSS_LOG_LEVEL=INFO
BSS_TENANT_DEFAULT=DEFAULT

# Operator policy flags.
#   BSS_ALLOW_ADMIN_RESET — gates the schema-wipe admin endpoints used
#     by `make reset-db` + scenario harnesses. Set to true ONLY on
#     dev/scratch databases; never in production.
#   BSS_ALLOW_DESTRUCTIVE — gates a few CLI commands (e.g. `bss payment
#     remove-method`). Off by default; the CLI prompts the operator if
#     they try a destructive op without it.
#   BSS_REQUIRE_KYC — Phase 4+ KYC enforcement on order placement.
#   BSS_ENABLE_TEST_ENDPOINTS — exposes the /dev/* tokenizer endpoint
#     in the payment service for the dev `bss payment add-card` CLI.
BSS_ALLOW_ADMIN_RESET=false
BSS_ALLOW_DESTRUCTIVE=false
BSS_REQUIRE_KYC=false
BSS_ENABLE_TEST_ENDPOINTS=false

# ════════════════════════════════════════════════════════════════════
# Clock (Phase 2+)
# ════════════════════════════════════════════════════════════════════
# Every business-logic site must read `bss_clock.now()`, never
# `datetime.utcnow()` (the doctrine-check grep enforces). The clock
# admin endpoint lets scenarios freeze / advance time deterministically.
BSS_CLOCK_MODE=system

# ════════════════════════════════════════════════════════════════════
# BSS perimeter API tokens (v0.3 default + v0.9 named)
# ════════════════════════════════════════════════════════════════════
# Every BSS service requires `X-BSS-API-Token` on every request. The
# token is validated against a TokenMap loaded from the env vars below.
# A successful match resolves a `service_identity` that flows into
# auth_context, audit.domain_event, structlog, and OTel spans.
#
# The shared "changeme" sentinel below is REJECTED at startup —
# generate a real token before running services:
#
#   openssl rand -hex 32
#
# Rotation procedure (per-token aware): docs/runbooks/api-token-rotation.md

# Default identity (v0.3+) — orchestrator, CSR console, scenarios all
# carry this. Receiving services resolve service_identity="default".
BSS_API_TOKEN=changeme

# Self-serve customer portal identity (v0.9+). Generated separately so
# a leaked portal credential rotates independently of the orchestrator's
# token. Receiving services resolve service_identity="portal_self_serve"
# from validation against this token. If unset during a staged rollout,
# the portal falls back to BSS_API_TOKEN and a warning is logged.
# BSS_PORTAL_SELF_SERVE_API_TOKEN=

# Operator cockpit identity (v0.13+). Stamped on every cockpit-driven
# downstream call so the audit trail cleanly distinguishes operator
# action from customer / partner / scenario action. Both surfaces of
# the cockpit (CLI REPL canonical + browser veneer at /cockpit/...)
# carry this token via NamedTokenAuthProvider("operator_cockpit", ...).
# Falls back to BSS_API_TOKEN during staged rollout (logs a warning).
# BSS_OPERATOR_COCKPIT_API_TOKEN=

# Future named tokens follow the BSS_<NAME>_API_TOKEN pattern. The
# loader derives service_identity from the env var name:
#   BSS_CSR_API_TOKEN          → service_identity="csr"     (v0.12)
#   BSS_PARTNER_ACME_API_TOKEN → service_identity="partner_acme"
# Each named token must be ≥32 chars and distinct from every other
# token in the map (sharing a token across surfaces defeats the point).

# ════════════════════════════════════════════════════════════════════
# LLM (OpenRouter via openai SDK; no LiteLLM hop)
# ════════════════════════════════════════════════════════════════════
BSS_LLM_BASE_URL=https://openrouter.ai/api/v1
BSS_LLM_MODEL=google/gemma-4-26b-a4b-it
BSS_LLM_API_KEY=sk-or-v1-replace-me
BSS_LLM_HTTP_REFERER=https://github.com/samurai-bot/bss-cli
BSS_LLM_APP_NAME=bss-cli

# ════════════════════════════════════════════════════════════════════
# Chat caps (v0.12)
# ════════════════════════════════════════════════════════════════════
# Per-customer hourly request cap (in-memory sliding window) and
# monthly cost ceiling (rolled up from OpenRouter token counts × per-
# model rate, persisted in audit.chat_usage). On trip, the chat route
# returns a templated "I've reached today's chat budget" response —
# never a raw error. Defaults bound a runaway customer at ~150 turns /
# month at Gemma 4 26B A4B pricing.
BSS_CHAT_RATE_PER_CUSTOMER_PER_HOUR=20
BSS_CHAT_COST_CAP_PER_CUSTOMER_PER_MONTH_CENTS=200
BSS_CHAT_RATE_PER_IP_PER_HOUR=60

# ════════════════════════════════════════════════════════════════════
# OpenTelemetry tracing (v0.2)
# ════════════════════════════════════════════════════════════════════
# All-in-one (docker-compose.infra.yml): use compose service name
#   BSS_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
# BYOI: point at your Jaeger host (see docs/runbooks/jaeger-byoi.md)
BSS_OTEL_ENABLED=true
BSS_OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318
BSS_OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
BSS_OTEL_SERVICE_NAME_PREFIX=bss
BSS_OTEL_SAMPLING_RATIO=1.0

# ════════════════════════════════════════════════════════════════════
# Portal auth (v0.8) — self-serve portal only
# ════════════════════════════════════════════════════════════════════
# Pepper used to HMAC-SHA-256 every OTP / magic-link / step-up code
# before storage. The "changeme" sentinel is REJECTED at portal
# startup — generate via: openssl rand -hex 32
# Rotation procedure: docs/runbooks/portal-auth.md
BSS_PORTAL_TOKEN_PEPPER=changeme

# Local dev only — set to 1 to drop the Secure cookie attribute
# (required when serving the portal over plain HTTP on localhost).
# Compose dev profile defaults this via docker-compose.yml's
# `${BSS_PORTAL_DEV_INSECURE_COOKIE:-1}`; production deployments
# should override to 0 and terminate TLS upstream of the portal.
BSS_PORTAL_DEV_INSECURE_COOKIE=1

# Public URL the portal is reachable at. Used to render absolute
# magic-link URLs inside outbound emails (Resend in production), and
# as the base for Didit KYC return URLs. Localhost works in dev;
# production deployments set this to the public host.
BSS_PORTAL_PUBLIC_URL=http://localhost:9001

# Rate-limit caps. Defaults match phases/V0_8_0.md §1.4. Override per
# deployment if needed; the windows are seconds.
BSS_PORTAL_LOGIN_PER_EMAIL_MAX=3
BSS_PORTAL_LOGIN_PER_EMAIL_WINDOW_S=900
BSS_PORTAL_LOGIN_PER_IP_MAX=10
BSS_PORTAL_LOGIN_PER_IP_WINDOW_S=3600
BSS_PORTAL_VERIFY_PER_EMAIL_MAX=10
BSS_PORTAL_VERIFY_PER_EMAIL_WINDOW_S=900
BSS_PORTAL_STEPUP_PER_SESSION_MAX=5
BSS_PORTAL_STEPUP_PER_SESSION_WINDOW_S=900

# ════════════════════════════════════════════════════════════════════
# Portal email (v0.14) — Resend or local dev mailbox
# ════════════════════════════════════════════════════════════════════
# Provider: 'logging' (writes magic-link OTPs to a tail-able file),
# 'noop' (test-only, no IO), or 'resend' (Resend HTTP API; production).
# `BSS_PORTAL_EMAIL_ADAPTER` is the v0.8 alias — still accepted with
# a deprecation warning; will be dropped post-v0.16.
#
# Configure interactively via: bss onboard --domain email
BSS_PORTAL_EMAIL_PROVIDER=logging
BSS_PORTAL_DEV_MAILBOX_PATH=/tmp/bss-portal-mailbox.log

# Resend (production). Keys can be scoped 'send-only' (recommended
# least-privilege production posture). The webhook secret is read by
# the portal's POST /webhooks/resend route, which records bounces /
# complaints / deliveries to integrations.webhook_event.
# BSS_PORTAL_EMAIL_RESEND_API_KEY=re_xxx
# BSS_PORTAL_EMAIL_RESEND_WEBHOOK_SECRET=whsec_xxx
# BSS_PORTAL_EMAIL_FROM="BSS-CLI <noreply@mail.example.com>"

# ════════════════════════════════════════════════════════════════════
# KYC verification (v0.15) — Didit or prebaked
# ════════════════════════════════════════════════════════════════════
# Provider: 'prebaked' (deterministic per-customer attestation, no
# external calls — used by hero scenarios + the v0.12 14-day soak
# corpus) or 'didit' (Didit hosted UI, HMAC-signed webhook is the
# trust anchor — see DECISIONS 2026-05-02).
#
# Configure interactively via: bss onboard --domain kyc
BSS_PORTAL_KYC_PROVIDER=prebaked

# Didit (production / sandbox). Workflow id is a raw UUID from the
# Didit dashboard. The webhook secret is non-negotiable — the API
# decision endpoint has no signature, so the HMAC-signed webhook is
# the only authenticated channel; without the secret, any portal-
# observed attestation is uncorroborated and policy rejects it.
# BSS_PORTAL_KYC_DIDIT_API_KEY=
# BSS_PORTAL_KYC_DIDIT_WORKFLOW_ID=
# BSS_PORTAL_KYC_DIDIT_WEBHOOK_SECRET=

# Sandbox affordances. BOTH must default false in production; both
# are refused at startup if BSS_ENV=production.
#
# BSS_KYC_ALLOW_PREBAKED — accept attestations with provider="prebaked"
#   in production. Default reject; outside production default accept
#   (so hero scenarios + 14-day soak corpus keep working).
#
# BSS_KYC_ALLOW_DOC_REUSE — bypasses the document-hash uniqueness
#   policy. Required for sandbox testing because Didit sandbox returns
#   a stable test NRIC for every verification — without this, every
#   second-and-later sandbox signup trips the uniqueness check. NEVER
#   true in production (real persons have globally unique document
#   numbers by definition).
# BSS_KYC_ALLOW_PREBAKED=false
# BSS_KYC_ALLOW_DOC_REUSE=false

# ════════════════════════════════════════════════════════════════════
# Payment (v0.16) — Stripe or in-process mock
# ════════════════════════════════════════════════════════════════════
# Provider: 'mock' (in-process MockTokenizerAdapter; preserves every
# v0.1 FAIL/DECLINE test affordance — hero scenarios use this) or
# 'stripe' (StripeTokenizerAdapter against Stripe's REST API).
#
# Configure interactively via: bss onboard --domain payment
# Cutover playbook (mock → stripe): docs/runbooks/stripe-cutover.md
BSS_PAYMENT_PROVIDER=mock

# Stripe (production / sandbox). Keys must agree on mode (both test
# or both live); the publishable key is the only one the browser sees
# (rendered into the Elements iframe). The webhook secret is non-
# negotiable — without it the receiver silently 401s every Stripe
# delivery and reconciliation never happens.
# BSS_PAYMENT_STRIPE_API_KEY=sk_test_xxx_or_sk_live_xxx
# BSS_PAYMENT_STRIPE_PUBLISHABLE_KEY=pk_test_xxx_or_pk_live_xxx
# BSS_PAYMENT_STRIPE_WEBHOOK_SECRET=whsec_xxx

# Sandbox affordance. Lets the same Stripe test pm_* re-attach to
# different BSS customers (Stripe's pm_card_visa is a single test
# card shared across many sandbox customers). Refused at startup
# if paired with sk_live_*. NEVER true in production.
# BSS_PAYMENT_ALLOW_TEST_CARD_REUSE=false

# ════════════════════════════════════════════════════════════════════
# Live-sandbox soak (v0.16 Track 5; optional)
# ════════════════════════════════════════════════════════════════════
# Set to a publicly-reachable URL serving this BSS instance's
# /webhooks/stripe (Tailscale Funnel, ngrok, prod URL). Enables the
# soak's Tier 5 webhook round-trip test:
#   BSS_NIGHTLY_SANDBOX=true \
#     PYTHONPATH=services/payment:scenarios \
#     uv run --package payment pytest scenarios/live_sandbox/
# Without this, Tier 5 skips cleanly. Other tiers still run.
# Runbook: docs/runbooks/three-provider-sandbox-soak.md
# BSS_PAYMENT_WEBHOOK_PUBLIC_URL=https://<your-funnel-host>/webhooks/stripe

# ════════════════════════════════════════════════════════════════════
# eSIM provider (v0.15+) — sim/onbglobal/esim_access
# ════════════════════════════════════════════════════════════════════
# v0.15 ships only the simulator (`sim`); the two real provider stubs
# (`onbglobal`, `esim_access`) raise on first use with a v0.16+
# pointer message — those impls are NDA-gated and ship post-v0.16.
BSS_ESIM_PROVIDER=sim

# ════════════════════════════════════════════════════════════════════
# Inventory pool ops (v0.17)
# ════════════════════════════════════════════════════════════════════
# When the available MSISDN count drops to (or below) this threshold,
# the next reservation emits an `inventory.msisdn.pool_low` audit event
# so operators see the nudge in cockpit. Replenish via:
#   bss inventory msisdn add-range <prefix> <count>
BSS_INVENTORY_MSISDN_POOL_LOW_THRESHOLD=50

# ════════════════════════════════════════════════════════════════════
# Subscription renewal worker (v0.18)
# ════════════════════════════════════════════════════════════════════
# In-process tick loop in the subscription service that polls
# subscription.subscription for due rows and dispatches renew()
# automatically (no separate scheduler container — multi-replica safety
# via FOR UPDATE SKIP LOCKED in the sweep query). 0 disables the worker
# entirely (useful when running multiple subscription replicas behind
# an external orchestrator, or in test environments). Manual paths
# (CLI, cockpit `subscription.renew_now`, scenario action) stay as
# operator escape hatches independent of this setting.
BSS_RENEWAL_TICK_SECONDS=60

# Lookahead window for the upcoming-renewal reminder email. The
# subscription service's renewal worker selects active subs whose
# next_renewal_at falls inside [now, now + N seconds] and sends one
# reminder email per period (deduped via subscription.renewal_reminder_sent_at).
# Default 86400 = 24h (the email reads "your bundle renews tomorrow").
# Set to 0 to disable the reminder sweep entirely without changing the
# email provider — the renewal sweep keeps running. The email goes
# through the same EmailAdapter the portal uses (BSS_PORTAL_EMAIL_PROVIDER).
BSS_RENEWAL_REMINDER_LOOKAHEAD_SECONDS=86400
